---
import { generateDerivedCSS } from '../theme';

interface Props {
  title: string;
}
const { title } = Astro.props;

const derivedCSS = generateDerivedCSS();
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Averia+Serif+Libre:wght@300;400;700&family=JetBrains+Mono:wght@400;700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <title>{title}</title>
  <style set:html={derivedCSS}></style>
  <script is:inline>
    (function() {
      const saved = localStorage.getItem('theme');
      const prefer = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      document.documentElement.dataset.theme = saved || prefer;
    })();
  </script>
</head>
<body>
  <slot />
</body>
</html>
