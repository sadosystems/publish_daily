---
interface Props {
  slug: string;
  title: string;
  preview: string;
}
const { slug, title, preview } = Astro.props;
---
<div class="chip-writing">
  <h2>{title}</h2>
  <div class="chip-writing-body" set:html={preview} />
  <a class="prose-fade" href={`/writing/${slug}`}>continue reading &rarr;</a>
</div>
