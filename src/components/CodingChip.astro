---
import type { PRData } from '../lib/github';

interface Props {
  dateKey: string;
  pr: PRData;
}
const { dateKey, pr } = Astro.props;

const mergedPath = 'M5.45 5.154A4.25 4.25 0 0 0 9.25 7.5h1.378a2.251 2.251 0 1 1 0 1.5H9.25A5.734 5.734 0 0 1 5 7.123v3.505a2.25 2.25 0 1 1-1.5 0V5.372a2.25 2.25 0 1 1 1.95-.218ZM4.25 13.5a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm8.5-4.5a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5ZM4.25 4a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Z';
const openPath = 'M1.5 3.25a2.25 2.25 0 1 1 3 2.122v5.256a2.251 2.251 0 1 1-1.5 0V5.372A2.25 2.25 0 0 1 1.5 3.25Zm5.677-.177L9.573.677A.25.25 0 0 1 10 .854V2.5h1A2.5 2.5 0 0 1 13.5 5v5.628a2.251 2.251 0 1 1-1.5 0V5a1 1 0 0 0-1-1h-1v1.646a.25.25 0 0 1-.427.177L7.177 3.427a.25.25 0 0 1 0-.354ZM3.75 2.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm0 9.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm8.25.75a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0Z';

const iconPath = pr.merged ? mergedPath : openPath;
const iconColor = pr.merged ? '#a371f7' : '#3fb950';

const tot = pr.adds + pr.dels;
const aB = tot > 0 ? Math.round((pr.adds / tot) * 5) : 0;
const dB = tot > 0 ? Math.round((pr.dels / tot) * 5) : 0;
const nB = Math.max(0, 5 - aB - dB);
---
<div class="chip-coding" id={`chip-${dateKey}-coding`}>
  <div class="pr-title-row">
    <svg width="16" height="16" viewBox="0 0 16 16" fill={iconColor}><path d={iconPath}></path></svg>
    <span class="pr-title">{pr.title} <span class="pr-num">#{pr.num}</span></span>
  </div>
  <div class="pr-meta-line">
    <span class={`badge ${pr.merged ? 'merged' : 'open'}`}>
      <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d={iconPath}></path></svg>
      {pr.merged ? 'Merged' : 'Open'}
    </span>
    <span class="sep">&middot;</span>
    <span>{pr.files} file{pr.files > 1 ? 's' : ''}</span>
    <span class="sep">&middot;</span>
    <span>{pr.commits} commit{pr.commits > 1 ? 's' : ''}</span>
    <span class="sep">&middot;</span>
    <span class="additions">+{pr.adds}</span>
    <span class="deletions">&minus;{pr.dels}</span>
    <span class="diffbar">
      {Array.from({ length: aB }, () => null).map(() => <span class="b-add" />)}
      {Array.from({ length: dB }, () => null).map(() => <span class="b-del" />)}
      {Array.from({ length: nB }, () => null).map(() => <span class="b-neu" />)}
    </span>
  </div>
  <div class="pr-desc">{pr.desc}</div>
</div>
